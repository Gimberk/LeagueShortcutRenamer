<Window x:Name="SelectShortcutPath" x:Class="LSR.src.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LSR.src"
        mc:Ignorable="d"
        Title="Select Shortcut Path" Height="401" Width="468" Background="#FF333333" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Closing="SelectShortcutPath_Closing">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="ExecPathTxt" TextWrapping="Wrap" Margin="102,171,0,0" Text="League Executable Path" FontSize="18" HorizontalAlignment="Left" VerticalAlignment="Top" Height="30" Width="232" FontFamily="Segoe UI"/>
        <TextBox x:Name="ShortcutPathTxt" TextWrapping="Wrap" Margin="102,69,0,0" Text="League Shortcut Path" FontSize="18" VerticalAlignment="Top" HorizontalAlignment="Left" Width="232" RenderTransformOrigin="0.5,0.5" Height="30">
            <TextBox.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleX="0"/>
                    <RotateTransform/>
                    <TranslateTransform X="0"/>
                </TransformGroup>
            </TextBox.RenderTransform>
        </TextBox>
        <Label Content="OR" Margin="0,118,0,0" Background="Transparent" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Top" FontFamily="Franklin Gothic Medium" FontSize="24" RenderTransformOrigin="0.581,0.139"/>
        <Button x:Name="ShortcutBrowseBtn" Content="Browse" HorizontalAlignment="Left" VerticalAlignment="Top" Height="30" Width="50" Margin="339,69,0,0" Click="ShortcutBrowseBtn_Click"/>
        <Button x:Name="ExecBrowseBtn" Content="Browse" Margin="339,171,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Height="30" Width="50" Click="ExecBrowseBtn_Click"/>
        <Button x:Name="SaveBtn" Content="Save" Margin="102,258,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Height="48" Width="287" FontSize="26" Click="SaveBtn_Click"/>
        <Label Content="?" Foreground="White" Margin="72,167,0,0" FontFamily="Franklin Gothic Medium" FontSize="24" HorizontalAlignment="Left" VerticalAlignment="Top" MouseEnter="Label_MouseEnter"/>
        <Label Content="?" Foreground="White" Margin="72,65,0,0" FontFamily="Franklin Gothic Medium" FontSize="24" HorizontalAlignment="Left" VerticalAlignment="Top" MouseEnter="Label_MouseEnter_1"/>

    </Grid>
</Window>
