<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LSR"
        xmlns:src="clr-namespace:LSR.src" x:Name="LSR" x:Class="LSR.MainWindow"
        mc:Ignorable="d"
        Title="League Shortcut Renamer" Height="450" Width="827" Background="#FF333333" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Grid Margin="0,0,0,-6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Label x:Name="Title" Content="Welcome to the League Shortcut Renamer!" Margin="0,16,0,0" FontSize="36" Foreground="#FF9149FF" FontFamily="Franklin Gothic Medium" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Button x:Name="SelectPaths" Content="Update Information" Margin="27,86,0,0" Click="SelectPaths_Click" Width="174" Height="43" VerticalAlignment="Top" HorizontalAlignment="Left" FontSize="16"/>
        <Label Content="Select a Shortcut Format:" Margin="27,141,0,0" FontSize="24" Foreground="#FF969696" FontFamily="Franklin Gothic Medium" HorizontalAlignment="Left" VerticalAlignment="Top" IsEnabled="False"/>
        <Label x:Name="PathLbl" Content="None&#xD;&#xA;" Foreground="White" FontFamily="Franklin Gothic Medium" Margin="216,86,0,0" FontSize="16" VerticalAlignment="Top" Height="43" HorizontalAlignment="Left" Width="601"/>
        <Button x:Name="EnableBtn" Content="Enable" Margin="27,271,585,100" FontSize="24" Foreground="#FF00FF1B" Click="EnableBtn_Click"/>
        <Button x:Name="DisableBtn" Content="Disable" Margin="27,345,585,26" FontSize="24" Foreground="#FFD02222" IsEnabled="False" Click="DisableBtn_Click"/>
        <RadioButton x:Name="LP" Content="Current League O' Legends LP" Margin="27,178,0,0" FontFamily="Franklin Gothic Medium" FontSize="16" Foreground="White" Checked="Current_Checked" HorizontalAlignment="Left" VerticalAlignment="Top" Width="230" Height="17"/>
        <RadioButton x:Name="None" Content="None (Sets to standard)" Margin="27,226,0,0" FontFamily="Franklin Gothic Medium" FontSize="16" Foreground="White" Checked="Current_Checked" HorizontalAlignment="Left" VerticalAlignment="Top" Width="180" Height="17"/>
        <RadioButton x:Name="MOTD" Content="Message of the day (MOTD) from yours truly!" Margin="27,202,0,0" FontFamily="Franklin Gothic Medium" FontSize="16" Foreground="White" Checked="Current_Checked" HorizontalAlignment="Left" VerticalAlignment="Top" Width="323" Height="17"/>
        <Label x:Name="SignedInLbl" Content="Signed In As: xHekpo3ma#yes" Foreground="White" Margin="247,351,0,0" FontFamily="Franklin Gothic Medium" FontSize="26" HorizontalAlignment="Left" VerticalAlignment="Top" Height="43" Width="570"/>
        <Button x:Name="ShowLegalBtn" Content="Show Legal Boilerplate" Margin="615,86,0,0" Click="ShowLegalBtn_Click" Width="174" Height="43" VerticalAlignment="Top" HorizontalAlignment="Left" FontSize="16" Background="#FF917BFF" BorderBrush="#FF5647A0"/>
    </Grid>
</Window>