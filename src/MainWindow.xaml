<Window x:Name="LSR" x:Class="LSR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LSR"
        mc:Ignorable="d"
        Title="League Shortcut Renamer" Height="450" Width="827" Background="#FF333333">
    <Grid Margin="0,0,0,-6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Label x:Name="Title" Content="Welcome to the League Shortcut Renamer!" Margin="0,16,0,0" FontSize="36" Foreground="#FF9149FF" FontFamily="Franklin Gothic Medium" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <Label Content="Select a Shortcut Format:" Margin="27,81,0,0" FontSize="24" Foreground="#FF969696" FontFamily="Franklin Gothic Medium" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <RadioButton x:Name="Current" Content="Current LP" HorizontalAlignment="Left" Margin="27,118,0,0" VerticalAlignment="Top" Width="97" Background="#FFC8C8C8" Foreground="White" BorderBrush="Red" FontFamily="Franklin Gothic Medium" FontSize="16" IsChecked="True"/>
        <RadioButton x:Name="MOTD" Content="Message of the Day from Yours Truly" HorizontalAlignment="Left" Margin="27,138,0,0" VerticalAlignment="Top" Width="272" Background="#FFC8C8C8" Foreground="White" BorderBrush="Red" FontFamily="Franklin Gothic Medium" FontSize="16"/>
    </Grid>
</Window>
